{
  "name": "sigil",
  "version": "0.1.0",
  "description": "A terminal coding assistant with a living, reactive ANSI-art visualizer, built on the Claude Agent SDK.",
  "type": "module",
  "license": "MIT",
  "author": "Bourne Choi",
  "homepage": "https://github.com/bournechoi4353/CTA#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bournechoi4353/CTA.git"
  },
  "bugs": {
    "url": "https://github.com/bournechoi4353/CTA/issues"
  },
  "keywords": [
    "cli",
    "terminal",
    "tui",
    "ansi",
    "claude",
    "ai",
    "coding-assistant",
    "agent",
    "generative-art",
    "visualizer"
  ],
  "bin": {
    "sigil": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "CREDITS.md"
  ],
  "scripts": {
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.181",
    "zod": "^4.4.3"
  }
}
